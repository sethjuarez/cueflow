{
  "id": "demo-ready",
  "title": "Prepare demo",
  "schemaVersion": 1,
  "steps": [
    {
      "id": "open-cueflow",
      "kind": "launchUrl",
      "url": "https://cueflow.dev",
      "retry": {
        "maxAttempts": 1,
        "backoff": "none"
      },
      "onError": "stop"
    },
    {
      "id": "focus-browser",
      "kind": "focusWindow",
      "target": {
        "appName": "Browser",
        "titleContains": "Cueflow"
      },
      "retry": {
        "maxAttempts": 1,
        "backoff": "none"
      },
      "onError": "stop"
    }
  ]
}
