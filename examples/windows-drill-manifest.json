{
  "id": "windows-foundation-drills",
  "evidenceDir": "../target/cueflow-drill-evidence",
  "drills": [
    {
      "id": "settings-actionability",
      "path": "windows-actionability-readiness-drill.json",
      "expectedOutcome": "succeeded",
      "policyProfile": "evidence",
      "allowPathOnlySelectors": true,
      "pruneEvidenceBeforeRun": true,
      "repeat": 2
    },
    {
      "id": "missing-window-timeout",
      "path": "windows-missing-window-timeout-drill.json",
      "expectedOutcome": "failed",
      "expectedFailureKind": "timeout",
      "expectedErrorContains": "step timed out",
      "expectedMaxDurationMillis": 1500
    },
    {
      "id": "image-target-policy",
      "path": "windows-image-target-policy-drill.json",
      "expectedOutcome": "executorError",
      "expectedErrorContains": "image targets require explicit allowImageTargets approval",
      "expectedMaxDurationMillis": 500
    },
    {
      "id": "path-only-policy",
      "path": "windows-path-only-policy-drill.json",
      "expectedOutcome": "executorError",
      "expectedErrorContains": "path-only accessibility selectors require explicit allowPathOnlySelectors approval",
      "expectedMaxDurationMillis": 500
    },
    {
      "id": "coordinate-policy",
      "path": "windows-coordinate-policy-drill.json",
      "expectedOutcome": "executorError",
      "expectedErrorContains": "coordinate targets require explicit allowCoordinateTargets approval",
      "expectedMaxDurationMillis": 500
    },
    {
      "id": "evidence-size-policy",
      "path": "windows-actionability-readiness-drill.json",
      "expectedOutcome": "succeeded",
      "policyProfile": "evidence",
      "allowPathOnlySelectors": true,
      "evidenceMaxArtifactBytes": 1,
      "pruneEvidenceBeforeRun": true,
      "expectedLogContains": "evidence artifact exceeded configured size limit"
    }
  ]
}
