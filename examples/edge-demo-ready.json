{
  "id": "edge-demo-ready",
  "title": "Prepare Edge demo state",
  "description": "Return the browser to google.com without coordinates or app-specific scripting.",
  "schemaVersion": 1,
  "steps": [
    {
      "id": "launch-google",
      "kind": "launchUrl",
      "url": "https://google.com",
      "timeout": {
        "millis": 10000
      },
      "retry": {
        "maxAttempts": 2,
        "delay": {
          "millis": 500
        },
        "backoff": "linear"
      },
      "onError": "stop"
    },
    {
      "id": "wait-for-google",
      "kind": "waitFor",
      "condition": {
        "kind": "windowExists",
        "target": {
          "titleContains": "Google"
        }
      },
      "timeout": {
        "millis": 3000
      },
      "retry": {
        "maxAttempts": 1,
        "backoff": "none"
      },
      "onError": "stop"
    },
    {
      "id": "focus-google",
      "kind": "focusWindow",
      "target": {
        "titleContains": "Google"
      },
      "timeout": {
        "millis": 3000
      },
      "retry": {
        "maxAttempts": 1,
        "backoff": "none"
      },
      "onError": "stop"
    }
  ]
}
